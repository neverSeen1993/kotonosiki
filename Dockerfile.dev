FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json* ./
RUN npm ci

# Source code is mounted as a volume — no COPY needed

EXPOSE 5173 3001

# Run both Vite dev server and API server concurrently
CMD sh -c "npx tsx watch server/index.ts & npx vite --host 0.0.0.0 --port 5173"
